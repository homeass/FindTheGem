<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    tools:context=".SplashActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- App Icon / Diamond Emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💎"
            android:textSize="120sp"
            android:letterSpacing="0.1"
            android:contentDescription="@string/app_name" />

        <!-- App Name -->
        <TextView
            android:id="@+id/app_name_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-medium" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_tagline"
            android:textColor="@color/white_alpha_80"
            android:textSize="16sp"
            android:letterSpacing="0.1" />

        <!-- Loading Indicator -->
        <ProgressBar
            android:id="@+id/setup_progress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="48dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/white"
            android:indeterminateTintMode="src_in" />

        <!-- Setup Status Text -->
        <TextView
            android:id="@+id/setup_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/white_alpha_80"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Error area (shown when Termux not found etc.) -->
        <LinearLayout
            android:id="@+id/setup_error_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/setup_error_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/setup_retry_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/setup_retry"
                android:textColor="@color/white"
                android:backgroundTint="#40FFFFFF"
                android:visibility="gone" />

            <Button
                android:id="@+id/setup_termux_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/setup_install_termux"
                android:textColor="@color/white"
                android:backgroundTint="#40FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
